# Copy this file to .env (local) or set these as Environment Variables
# in Hostinger hPanel > Node.js app, then restart the app.

# MySQL connection (Hostinger hPanel > Databases > MySQL Databases)
# If server.cjs runs on the SAME Hostinger hosting account as the database,
# DB_HOST is usually "localhost". If it runs elsewhere, use the remote
# hostname/IP shown in hPanel and make sure remote MySQL access ("%" or
# your server's IP) is enabled under Remote MySQL.
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_DATABASE=
DB_SSL=false

# Port the Node process listens on. On Hostinger's Node.js app hosting this
# is injected automatically by Passenger — leave it unset there.
PORT=8000
